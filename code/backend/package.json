{
  "name": "hokiestudy-backend",
  "version": "1.0.0",
  "description": "Backend server for HokieStudy - VT study partner matching app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --rootDir ../../ --testMatch **/tests/**/*.test.js --forceExit --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": "../../",
    "testMatch": ["**/tests/**/*.test.js"],
    "modulePaths": ["<rootDir>/code/backend/node_modules"]
  }
}
